{
  "$schema": ".interact/interact.schema.json",
  "components": {
    "Counter": {
      "importPath": "./components/Counter.js",
      "type": "content"
    },
    "Planet": {
      "importPath": "./components/Planet.js",
      "type": "content"
    },
    "NotFound": {
      "importPath": "./pages/404.js",
      "type": "page"
    },
    "NavBar": {
      "props": {
        "brandName": "Interact",
        "logoWidth": 20
      }
    }
  },
  "pages": {
    "providers": [
      {
        "importPath": "./cms/remote-markdown.js",
        "props": {
          "basePath": "https://raw.githubusercontent.com",
          "prefix": "/github"
        }
      }
    ]
  }
}