{
  "$schema": ".interact/interact.schema.json",
  "site": {
    "name": "Interact",
    "title": "Interact Documentation (that feels like an App)"
  },
  "components": {
    "Counter": {
      "importPath": "./components/Counter.tsx",
      "type": "markdown"
    },
    "Planet": {
      "importPath": "./components/Planet.js",
      "type": "markdown"
    },
    "NotFound": {
      "importPath": "./pages/404.tsx",
      "type": "page"
    },
    "Header": {
      "props": {
        "brandName": "nteract",
        "logoWidth": 24,
        "logoHeight": 24
      }
    }
  },
  "pages": {
    "providers": [
      {
        "importPath": "./cms/remote-markdown.tsx",
        "props": {
          "basePath": "https://raw.githubusercontent.com",
          "prefix": "/github"
        }
      }
    ]
  }
}